{
	"name": "@toreda/expressive-types",
	"version": "3.0.0",
	"public": true,
	"description": "Common mappings, aliases, and types used in Toreda TypeScript packages.",
	"main": "./dist/index.js",
	"typings": "./dist/index.d.ts",
	"scripts": {
		"lint": "yarn lint:nofix",
		"lint:nofix": "yarn lint",
		"lint:fix": "yarn eslint src/**/*.{js,ts,tsx} --quiet --fix",
		"build": "yarn ts-node ./esbuild.ts",
		"make:docs": "yarn typedoc",
		"make:depgraph": "yarn madge src/index.ts --image dependency-graph.png",
		"release:notes": "node ./scripts/extract-changelog-section.mjs",
		"release:prepare": "node ./scripts/prepare-changelog-release.mjs",
		"test": "yarn jest --coverage --maxWorkers=50%"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/toreda/expressive-types.git"
	},
	"keywords": [
		"Toreda",
		"expressive",
		"units",
		"types"
	],
	"author": "Toreda, Inc.",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/toreda/expressive-types/issues"
	},
	"homepage": "https://github.com/toreda/expressive-types#readme",
	"sideEffects": false,
	"resolutions": {
		"set-value": "^4.1.0",
		"glob-parent": "^6.0.2",
		"minimist": "^1.2.6",
		"marked": "^4.0.10",
		"chokidar": "^3.0.0"
	},
	"devDependencies": {
		"@cspotcode/source-map-support": "^0.8.1",
		"@swc-node/register": "^1.9.0",
		"@swc/core": "^1.15.33",
		"@swc/jest": "^0.2.36",
		"@swc/wasm": "^1.4.11",
		"@toreda/eslint-config": "^2.2.0",
		"@toreda/prettier-config": "^1.0.1",
		"@types/del": "^4.0.0",
		"@types/eslint": "^9.6.1",
		"@types/jest": "^29.5.12",
		"@types/node": "^20.11.30",
		"@typescript-eslint/eslint-plugin": "^7.4.0",
		"@typescript-eslint/parser": "^7.4.0",
		"del": "^7.1.0",
		"esbuild": "^0.20.2",
		"esbuild-plugin-d.ts": "^1.2.3",
		"esbuild-plugin-tsc": "^0.4.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-dtslint": "^3.0.2",
		"eslint-plugin-prettier": "^5.1.3",
		"expect-type": "^0.14.2",
		"gulp-typescript": "^6.0.0-alpha.1",
		"jest": "^30.4.2",
		"jest-cli": "^29.7.0",
		"prettier": "^3.2.5",
		"through2": "^4.0.2",
		"ts-node": "^10.9.2",
		"ts-register": "^0.1.0",
		"typedoc": "^0.25.12",
		"typescript": "5.3.3"
	},
	"prettier": "@toreda/prettier-config",
	"dependencies": {
		"marked": "^4.0.10"
	}
}
