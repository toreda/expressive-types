{
	"name": "@toreda/shared-types",
	"version": "3.0.0",
	"public": true,
	"description": "Common mappings, aliases, and types used in Toreda TypeScript packages.",
	"main": "./dist/index.js",
	"typings": "./dist/index.d.ts",
	"scripts": {
		"lint": "pnpm lint:nofix",
		"lint:nofix": "pnpm lint",
		"lint:fix": "pnpm eslint src/**/*.{js,ts,tsx} --quiet --fix",
		"build": "pnpm gulp",
		"build:nolint": "cross-env BUILD_LINT=false pnpm gulp",
		"make:docs": "pnpm typedoc",
		"release:notes": "node ./scripts/extract-changelog-section.mjs",
		"release:prepare": "node ./scripts/prepare-changelog-release.mjs",
		"test": "pnpm jest --coverage --maxWorkers=50%"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/toreda/shared-types.git"
	},
	"keywords": [
		"Toreda",
		"expressive",
		"units",
		"types"
	],
	"author": "Toreda, Inc.",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/toreda/shared-types/issues"
	},
	"homepage": "https://github.com/toreda/shared-types#readme",
	"sideEffects": false,
	"resolutions": {
		"set-value": "^4.1.0",
		"glob-parent": "^6.0.2",
		"minimist": "^1.2.6",
		"marked": "^4.0.10",
		"chokidar": "^3.0.0"
	},
	"devDependencies": {
		"@cspotcode/source-map-support": "^0.8.1",
		"@types/gulp": "^4.0.17",
		"@swc/core": "^1.15.33",
		"@swc/jest": "^0.2.39",
		"@toreda/eslint-config": "^3.1.0",
		"@toreda/prettier-config": "^1.0.1",
		"@types/eslint": "^9.6.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.7.0",
		"cross-env": "^7.0.3",
		"del": "^7.1.0",
		"esbuild": "^0.28.0",
		"esbuild-plugin-d.ts": "^1.3.1",
		"gulp": "^5.0.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-dtslint": "^3.0.2",
		"eslint-plugin-prettier": "^5.5.5",
		"expect-type": "^1.3.0",
		"jest": "^30.4.2",
		"prettier": "^3.8.3",
		"ts-node": "^10.9.2",
		"typedoc": "^0.25.12",
		"typescript": "5.3.3",
		"typescript-eslint": "^8.0.0"
	},
	"prettier": "@toreda/prettier-config",
	"dependencies": {
		"marked": "^4.0.10"
	}
}
